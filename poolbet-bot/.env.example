# PoolBet Bot - Template per le Variabili d'Ambiente 🚀
# Copia questo file in .env sul server e compila con i tuoi dati reali.
# NON caricare mai il file .env su GitHub!

# ── Telegram ──
BOT_TOKEN=tuo_token_qui
BOT_USERNAME=PoolBetBot
ADMIN_IDS=12345678,98765432

# ── Database ──
DATABASE_URL=postgresql://user:password@localhost:5432/poolbet
REDIS_URL=redis://localhost:6379/0

# ── Blockchain / Polygon ──
POLYGON_RPC_HTTP=https://polygon-mainnet.g.alchemy.com/v2/your-api-key
POLYGON_RPC_WS=wss://polygon-mainnet.g.alchemy.com/v2/your-api-key
HOT_WALLET_PRIVATE_KEY=tua_chiave_privata_qui
HOT_WALLET_MNEMONIC=tua_mnemonica_qui
COLD_WALLET_ADDRESS=tuo_indirizzo_cold_wallet_qui
USDT_CONTRACT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F

# ── Settings ──
CHALLENGE_STAKE=5.00
CHALLENGE_DURATION_H=24
HOT_WALLET_SWEEP_THRESHOLD=2000
MIN_WITHDRAWAL=10
FEE_WITHDRAWAL=0.50
